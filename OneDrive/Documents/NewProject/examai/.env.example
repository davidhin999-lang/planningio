# Backend — Google Gemini API key (required)
GEMINI_API_KEY=AIza...

# Flask environment (development | production)
FLASK_ENV=development

# Port for the Flask server (Railway sets this automatically)
PORT=5000

# Frontend — set this in production to your Railway backend URL
# e.g. https://gradeai-backend.up.railway.app
# Leave empty in local dev (Vite proxy handles /api calls)
VITE_API_URL=
